.DS_Store
__pycache__/
*.py[cod]

# Raw, requantified, model, and integrated-object data remain external.
data/raw/
data/processed/
results/intermediate/
results/models/
results/final/*.h5ad
results/final/*.h5mu

# Full peak-link tables are generated by the ATAC workflow.
results/annotations/peak_gene_links.tsv.gz
results/annotations/peak_gene_links.filtered.tsv.gz
results/annotations/peak_gene_link_summary.tsv

# Optional source table for regenerating the compact expression lookup.
results/dge/

# Large TFBS intermediates are regenerated by make figure2d_tfbs.
results/tfbs_gene_overlap/tfbs_motif_hits.tsv.gz
results/tfbs_gene_overlap_integrated/background_linked_peaks.tsv.gz
results/tfbs_gene_overlap_integrated/background_linked_peak_motif_hits.tsv.gz
results/tfbs_gene_overlap_integrated/background_reference_promoters.tsv.gz
results/tfbs_gene_overlap_integrated/background_reference_promoter_motif_hits.tsv.gz
results/tfbs_gene_overlap_integrated/standard_motif_enrichment/
